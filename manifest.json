{
  "name": "TrustLens Live",
  "description": "Verify claims on any webpage with AI-powered analysis and real-time Trust Scores.",
  "version": "3.1.0",
  "manifest_version": 3,
  "author": "TrustLens Team",
  "homepage_url": "https://trustlens.io",
  "minimum_chrome_version": "114",

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "notifications"
  ],

  "optional_permissions": [
    "alarms",
    "scripting"
  ],

  "host_permissions": [
    "https://trustlens-api.onrender.com/*"
  ],

  "optional_host_permissions": [
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "TrustLens Live - Verify with AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "commands": {
    "verify-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Verify selected text with TrustLens"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png",
        "icons/icon32.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; connect-src 'self' https://trustlens-api.onrender.com"
  },

  "incognito": "split"
}
